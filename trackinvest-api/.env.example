# TrackInvest API Configuration
# Copy to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# API Security
API_KEYS=sk-your-api-key-here

# JWT Auth (for multi-device login)
JWT_SECRET=your-random-secret-at-least-32-chars
JWT_EXPIRES_IN=30d

# ─── AI Provider (choose one) ───
# Google Gemini (free: 60 req/min, no CC) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# OR Groq (free: 30 req/min, Llama/Mixtral) — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# OR OpenAI (paid)
# OPENAI_API_KEY=sk-...

# ─── Free Database — Supabase (PostgreSQL 500MB free) ───
# Sign up: https://supabase.com → New project → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── Free Notifications ───
# Telegram Bot (completely free, unlimited)
# Create: https://t.me/BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=
# Get your chat ID: send a message to @userinfobot
TELEGRAM_CHAT_ID=

# ntfy.sh (free push notifications, no account)
NTFY_TOPIC=trackinvest-yourname

# Web Push (optional — for browser notifications)
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@trackinvest.app

# SMTP (optional — email fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Free Cloud Backup ───
# GitHub Personal Access Token (for Gist backup)
# Create: https://github.com/settings/tokens → enable gist scope
GITHUB_TOKEN=
# Optional: existing Gist ID to update (leave blank to create new)
GITHUB_GIST_ID=

# ─── Free External Data ───
# NewsAPI (free: 100 req/day) — https://newsapi.org/register
NEWSAPI_KEY=
# ExchangeRate-API (free: 1500 req/month) — https://www.exchangerate-api.com
EXCHANGERATE_API_KEY=

# Market Data (optional — Yahoo Finance works without key)
ALPHA_VANTAGE_API_KEY=

# Backup (local by default)
BACKUP_PROVIDER=local
