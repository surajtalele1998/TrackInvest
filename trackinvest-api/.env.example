# TrackInvest API Configuration
# Copy to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# API Security
API_KEYS=sk-your-api-key-here,sk-second-key-optional

# AI Provider (choose one)
# Google Gemini (recommended)
GEMINI_API_KEY=your-gemini-api-key
# OR OpenAI
# OPENAI_API_KEY=your-openai-api-key

# Market Data
# Default: Yahoo Finance (free, no key needed)
# Optional: Alpha Vantage for enhanced data
ALPHA_VANTAGE_API_KEY=

# Notifications
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# SMTP (for email fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Backup (optional S3/GCS)
BACKUP_PROVIDER=local
# BACKUP_S3_BUCKET=my-backup-bucket
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=

# Redis (optional — falls back to in-memory cache)
# REDIS_URL=redis://localhost:6379
