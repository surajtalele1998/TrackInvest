<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; padding: 40px; color: #1a1a2e; line-height: 1.6; max-width: 800px; margin: 0 auto; }
    h1 { color: #6c63ff; border-bottom: 2px solid #6c63ff; padding-bottom: 8px; }
    h2 { color: #333; margin-top: 28px; }
    .header { text-align: center; margin-bottom: 30px; }
    .header h1 { border-bottom: none; font-size: 26px; }
    .header p { color: #888; font-size: 13px; }
    .stat-grid { display: flex; gap: 16px; flex-wrap: wrap; margin: 20px 0; }
    .stat-card { flex: 1; min-width: 140px; background: #f8f7ff; border-radius: 12px; padding: 16px; text-align: center; }
    .stat-card .value { font-size: 22px; font-weight: 700; color: #6c63ff; }
    .stat-card .label { font-size: 12px; color: #888; margin-top: 4px; }
    table { width: 100%; border-collapse: collapse; margin: 16px 0; }
    th, td { padding: 10px 14px; text-align: left; border-bottom: 1px solid #eee; font-size: 14px; }
    th { background: #6c63ff; color: #fff; font-weight: 600; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
    .badge-up { background: #e8f5e9; color: #2e7d32; }
    .badge-down { background: #fce4ec; color: #c62828; }
    .footer { text-align: center; margin-top: 40px; padding-top: 15px; border-top: 1px solid #ddd; font-size: 11px; color: #aaa; }
    @media print { body { padding: 0; } .no-print { display: none; } }
  </style>
</head>
<body>
  <div class="header">
    <h1>TrackInvest</h1>
    <p><%= title %> — Generated on <%= date %></p>
  </div>

  <%- content %>

  <div class="footer">
    <p>TrackInvest — AI-Powered Wealth Management | <%- version %></p>
  </div>
</body>
</html>
